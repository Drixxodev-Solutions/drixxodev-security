# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example (with placeholders) is committed. (§7.4)

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/drixxodev

# 32-byte (64 hex chars) key for AES-256-GCM token encryption (§6.2, §7.2)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key-here

# LLM API keys — operator-held, never exposed to clients or frontend (§7.3)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Google OAuth app credentials (registered in Google Cloud Console) (§6.1)
# The SAME Google app powers both Gmail (email triage) and Google Calendar
# (meeting prep) — they differ only by scope. Whitelist BOTH redirect URIs on
# the app: {APP_BASE_URL}/oauth/callback/gmail and .../oauth/callback/gcal
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Slack OAuth app credentials (registered in Slack API dashboard) (§6.1)
SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret

# Public base URL of this app (used for OAuth redirect URIs)
APP_BASE_URL=https://app.yourcompany.com

# M3: Operator alert settings
# Daily LLM spend threshold (USD) across all clients; worker alerts the operator if exceeded.
# Defaults to $25 if not set.
DAILY_SPEND_ALERT_USD=25
# Email address to deliver operator alerts (usage_80, overage_pause, daily_spend).
# TODO(M4): wire up real email/Slack delivery in lib/alerts.ts using this value.
OPERATOR_ALERT_EMAIL=

# M4: Clerk operator authentication (§7 — never expose secret key to clients/browser)
# Get these from https://dashboard.clerk.com — create a new application.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is safe to expose in browser; it is not a secret.
# CLERK_SECRET_KEY is server-only — never commit a real value, never ship to browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Override Clerk's default routing URLs so the operator sign-in page renders correctly.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
